{
  "name": "@donnerknalli/webgpu-utils",
  "version": "1.0.0",
  "author": "hsimpson",
  "description": "WebGPU Utilities",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hsimpson/webgpu-utils"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint:ts": "eslint . --concurrency auto",
    "lint": "yarn check-types && yarn lint:ts",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "npm:publish": "yarn format:check && yarn lint && yarn build && yarn test && npm publish",
    "examples": "vite --config examples/vite.config.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "wgpu-matrix": "^3.4.2"
  }
}
